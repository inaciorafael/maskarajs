{
  "name": "maskarajs",
  "version": "1.0.0",
  "description": "Engine de máscaras declarativo — framework-agnostic, zero dependências, ~4kb",
  "main": "./mask.cjs.js",
  "module": "./mask.mjs",
  "types": "./mask.d.ts",
  "exports": {
    ".": {
      "import": "./mask.mjs",
      "require": "./mask.cjs.js",
      "types": "./mask.d.ts"
    },
    "./react": {
      "import": "./react.mjs",
      "require": "./react.cjs.js",
      "types": "./react.d.ts"
    }
  },
  "files": [
    "src",
    "mask.js",
    "mask.mjs",
    "mask.cjs.js",
    "mask.d.ts",
    "react.mjs",
    "react.cjs.js",
    "react.d.ts",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "sideEffects": false,
  "keywords": [
    "mask", "input-mask", "form", "cpf", "cnpj", "phone",
    "date", "money", "react", "vue", "svelte", "vanilla"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16"
  }
}
