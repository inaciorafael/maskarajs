{
  "name": "maskarajs",
  "version": "1.0.4",
  "description": "Engine de máscaras declarativo — framework-agnostic, zero dependências, ~4kb",
  "main": "./src/core/mask.cjs.js",
  "module": "./src/core/mask.mjs",
  "types": "./src/core/mask.d.ts",
  "scripts": {
    "build:min": "node scripts/build-min.mjs",
    "prepack": "npm run build:min",
    "test": "node test/mask.test.mjs"
  },
  "exports": {
    ".": {
      "import": "./src/core/mask.mjs",
      "require": "./src/core/mask.cjs.js",
      "types": "./src/core/mask.d.ts"
    },
    "./min": {
      "import": "./src/core/mask.min.mjs",
      "require": "./src/core/mask.min.cjs.js",
      "types": "./src/core/mask.d.ts"
    },
    "./react": {
      "import": "./src/adapters/react/index.mjs",
      "require": "./src/adapters/react/index.cjs.js",
      "types": "./src/adapters/react/index.d.ts"
    },
    "./vue": {
      "import": "./src/adapters/vue/index.mjs",
      "require": "./src/adapters/vue/index.cjs.js",
      "types": "./src/adapters/vue/index.d.ts"
    },
    "./presets/br": {
      "import": "./src/presets/br.mjs",
      "require": "./src/presets/br.cjs.js",
      "types": "./src/presets/br.d.ts"
    },
    "./presets/payment": {
      "import": "./src/presets/payment.mjs",
      "require": "./src/presets/payment.cjs.js",
      "types": "./src/presets/payment.d.ts"
    },
    "./presets/date": {
      "import": "./src/presets/date.mjs",
      "require": "./src/presets/date.cjs.js",
      "types": "./src/presets/date.d.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "sideEffects": false,
  "keywords": [
    "mask",
    "input-mask",
    "form",
    "cpf",
    "cnpj",
    "phone",
    "date",
    "money",
    "react",
    "vue",
    "svelte",
    "vanilla"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16"
  }
}
